# MAC OS Meta File
.DS_Store

# Simulation Output
sim_out/*

# Quartus generated files
quartus/db/
quartus/incremental_db/
quartus/output_files/
quartus/*.rpt
quartus/*.smsg
quartus/*.pin
quartus/*.sof
quartus/*.pof
quartus/*.jdi
quartus/*.qws
quartus/*.sopcinfo

# Platform Designer generated synthesis output (keep the .qsys, ignore generated HDL)
quartus/room_eq_system/synthesis/
quartus/room_eq_system/simulation/
db/*
greybox_tmp/*

# Questa Simulation (generated per-run in any test directory)
work/
fft_ii_0/
modelsim.ini
transcript

# Twiddle-factor hex files copied to CWD by sim_fft.tcl
capture_fft_fft_ii_0_*.hex

# qsys-generate simulation output under quartus/ip/
quartus/ip/**/simulation/

# lab3-hw Quartus build artifacts
lab3-hw/db/
lab3-hw/incremental_db/
lab3-hw/output_files/
lab3-hw/.qsys_edit/
lab3-hw/hps_isw_handoff/
lab3-hw/c5_pin_model_dump.txt
lab3-hw/hps_sdram_p0_all_pins.txt
lab3-hw/hps_sdram_p0_summary.csv
lab3-hw/soc_system.sopcinfo
lab3-hw/soc_system.srf
# Quartus PLL IP generated files (not needed for synthesis or Questa sim)
quartus/ip/PLL/*.bsf
quartus/ip/PLL/*.cmp
quartus/ip/PLL/*.ppf
quartus/ip/PLL/pll_sim.f
quartus/ip/PLL/pll_sim/aldec/
